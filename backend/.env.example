PORT=3000
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (Aiven MySQL / PlanetScale / etc.)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Production: set to your Vercel frontend URL (e.g. https://management-inventory.vercel.app)
FRONTEND_URL=
