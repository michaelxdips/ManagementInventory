# Frontend Environment Variables
# Nama variable HARUS VITE_API_BASE_URL (bukan VITE_API_URL)
#
# Local dev (default fallback ke localhost:3000, bisa dikosongkan):
VITE_API_BASE_URL=http://localhost:3000/api
#
# Production (Vercel): set di Vercel dashboard -> Settings -> Environment Variables
# Contoh: VITE_API_BASE_URL=https://management-inventory-backend.onrender.com/api
